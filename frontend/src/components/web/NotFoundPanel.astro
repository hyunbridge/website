---
interface Props {
  title?: string
  description?: string
  href?: string
  ctaLabel?: string
}

const {
  title = "페이지를 찾을 수 없습니다",
  description = "주소가 잘못되었거나 더 이상 제공되지 않는 페이지입니다.",
  href = "/",
  ctaLabel = "홈으로 돌아가기",
} = Astro.props
---

<div
  class="container flex min-h-[60vh] items-center justify-center py-12"
  transition:animate="fade"
>
  <div class="max-w-lg rounded-2xl border border-border/60 bg-card/70 p-8 text-center">
    <h1 class="text-3xl font-semibold">{title}</h1>
    <p class="mt-3 text-muted-foreground">{description}</p>
    <div class="mt-6">
      <a
        href={href}
        class="inline-flex rounded-full bg-foreground px-4 py-2 text-sm font-medium text-background"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</div>
