---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { Badge } from "@shared/components/ui/badge"
import { getProjects } from "@/lib/project-service"
import { getViewTransitionName } from "@/lib/view-transitions"

const projects = await getProjects()
---

<BaseLayout title="프로젝트 | Hyungyo Seo" description="프로젝트와 작업물을 확인해보세요.">
  <div class="container py-8 md:py-12" transition:animate="fade">
    <h1 class="mb-8 text-3xl font-bold md:text-4xl">프로젝트</h1>

    {
      projects.length === 0 ? (
        <div class="flex items-center justify-center py-12">
          <div class="mx-auto w-full max-w-lg rounded-2xl border border-dashed border-border/70 bg-card/50 px-6 py-8 text-center">
            <div class="mx-auto mb-4 inline-flex h-11 w-11 items-center justify-center rounded-full bg-muted text-muted-foreground">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-5 w-5"
                aria-hidden="true"
              >
                <path d="M3 7h18" />
                <path d="M6 3h4" />
                <path d="M14 3h4" />
                <rect x="3" y="7" width="18" height="14" rx="2" />
                <path d="M8 11h3v3H8z" />
                <path d="M13 11h3" />
                <path d="M13 15h5" />
              </svg>
            </div>
            <h2 class="text-xl font-semibold tracking-tight">프로젝트가 없습니다</h2>
            <p class="mt-2 text-sm text-muted-foreground">현재 공개된 프로젝트가 없습니다.</p>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <a href={`/projects/${project.slug || project.id}`} class="block h-full">
              <div class="flex h-full flex-col overflow-hidden rounded-xl border border-border bg-card transition-shadow hover:shadow-md">
                {project.cover_image && (
                  <img
                    src={project.cover_image}
                    alt={project.title}
                    class="h-48 w-full object-cover"
                    style={`view-transition-name:${getViewTransitionName("project", project.id, "image")}`}
                  />
                )}
                <div class="p-6">
                  <h2
                    class="text-xl font-semibold"
                    style={`view-transition-name:${getViewTransitionName("project", project.id, "title")}`}
                  >
                    {project.title}
                  </h2>
                  <p class="mt-3 line-clamp-3 text-sm text-muted-foreground">{project.summary}</p>
                </div>
                <div class="mt-auto flex flex-wrap gap-2 px-6 pb-6">
                  {project.tags?.map((tag) => (
                    <Badge variant="secondary">{tag.name}</Badge>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
