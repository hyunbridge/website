---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { NotionCvContent } from "@/components/web/notion-cv-content"
import { DownloadButton } from "@/features/cv/download-button"
import { getCVData } from "@/lib/notion"

let cv = null
let errorMessage = ""

try {
  cv = await getCVData()
} catch (error) {
  errorMessage =
    error instanceof Error ? error.message : "이력서를 불러오는 중 오류가 발생했습니다."
}
---

<BaseLayout title="이력서 | Hyungyo Seo" description="서현교의 이력서">
  <div class="container py-8 md:py-12">
    <div class="md:hidden">
      <div class="flex flex-row items-center justify-between">
        <h1 class="text-3xl font-bold md:text-4xl">서현교</h1>
        <DownloadButton client:load className="print:hidden" />
      </div>
      <div class="mt-6">
        {
          errorMessage ? (
            <div class="text-sm text-destructive">{errorMessage}</div>
          ) : (
            <NotionCvContent cv={cv} />
          )
        }
      </div>
    </div>

    <div class="hidden md:block">
      <div class="overflow-hidden rounded-lg bg-card shadow-lg">
        <div class="flex flex-row items-center justify-between bg-card p-6">
          <h1 class="text-3xl font-bold md:text-4xl">서현교</h1>
          <DownloadButton client:load className="print:hidden" />
        </div>
        <div class="p-6">
          {
            errorMessage ? (
              <div class="text-sm text-destructive">{errorMessage}</div>
            ) : (
              <NotionCvContent cv={cv} />
            )
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
