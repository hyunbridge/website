---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { BackLink } from "@/components/ui/back-link"
import { PostList } from "@/components/blog/post-list"
import NotFoundPanel from "@/components/web/NotFoundPanel.astro"
import { buildApiUrl } from "@/lib/api-client"
import { getPostsByTagId, isTagNotFoundError } from "@/lib/blog-service"
import { getAllPublishedTagsForBuild } from "@/lib/static-content"

export async function getStaticPaths() {
  const tags = await getAllPublishedTagsForBuild()
  return tags.map((tag) => ({
    params: { id: tag.id },
  }))
}

const { id } = Astro.params

if (!id) {
  return Astro.redirect("/blog/tags")
}

let tagName = "태그"
let posts: Awaited<ReturnType<typeof getPostsByTagId>>["posts"] = []
let tagFound = true

try {
  const response = await getPostsByTagId(id, 1, 10)
  tagName = response.tag.name
  posts = response.posts
} catch (error) {
  if (isTagNotFoundError(error)) {
    tagFound = false
    Astro.response.status = 404
  } else {
    throw error
  }
}
---

<BaseLayout
  title={`${tagName} | 블로그 태그 | Hyungyo Seo`}
  description={`${tagName} 태그가 달린 블로그 글을 둘러보세요.`}
>
  {
    !tagFound ? (
      <NotFoundPanel
        title="태그를 찾을 수 없습니다"
        description="요청한 블로그 태그가 없거나 더 이상 제공되지 않습니다."
        href="/blog/tags"
        ctaLabel="전체 태그로 돌아가기"
      />
    ) : (
      <div class="container py-8 md:py-12" transition:animate="fade">
        <div class="mb-8">
          <BackLink href="/blog/tags">전체 태그로 돌아가기</BackLink>
        </div>

        <h1 class="mb-8 text-3xl font-bold md:text-4xl">"{tagName}" 태그가 포함된 글</h1>

        <PostList
          client:load
          initialPosts={posts}
          nextPageBasePath={buildApiUrl("/posts", { tagId: id })}
        />
      </div>
    )
  }
</BaseLayout>
