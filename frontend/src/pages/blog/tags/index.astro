---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { Badge } from "@shared/components/ui/badge"
import { getAllPublishedTagsForBuild } from "@/lib/static-content"

const tags = await getAllPublishedTagsForBuild()
---

<BaseLayout title="블로그 태그 | Hyungyo Seo" description="태그별로 블로그 글을 둘러보세요.">
  <div class="container py-8 md:py-12">
    <h1 class="mb-8 text-3xl font-bold md:text-4xl">블로그 태그</h1>
    {
      tags.length === 0 ? (
        <div class="flex items-center justify-center py-12">
          <div class="max-w-lg rounded-2xl border border-border/60 bg-card/70 p-8 text-center">
            <h2 class="text-xl font-semibold">태그가 없습니다</h2>
            <p class="mt-3 text-muted-foreground">
              게시글이 발행되면 새로운 태그가 여기에 표시됩니다.
            </p>
          </div>
        </div>
      ) : (
        <div class="flex flex-wrap gap-3">
          {tags.map((tag) => (
            <a href={`/blog/tags/${tag.id}`}>
              <Badge variant="outline" className="px-3 py-2 text-sm">
                {tag.name}
              </Badge>
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
